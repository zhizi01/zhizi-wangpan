# 复制为 .env 后填写。安装脚本可在无 .env 时从本文件生成 .env。

# 数据库（库名需与 server/sql/init.sql 中一致，默认 zhizi_files）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=zhizi_files

# JWT
JWT_SECRET=请改为随机长字符串
JWT_EXPIRES_IN=7d

# SMTP（可选，用于注册/找回密码）
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 服务
PORT=3000
NODE_ENV=production

# 上传（相对路径时相对「运行 node 时的工作目录」，建议从仓库根启动）
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=2147483648

# 前端构建用；已部署静态资源需重新构建才会变
VITE_API_BASE_URL=http://localhost:3000/api
